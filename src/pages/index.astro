---
import Layout from '../layouts/Layout.astro';
import P5Sketch from '../components/P5Sketch.astro';
import Label from '../components/Label.astro';

---

<Layout>
    <!-- øvre BAR (fast højde) -->
    <div class="absolute top-0 left-0 w-full h-60 bg-[#46484a] z-50">

        
        <!-- Kontrol-panel: venstre tekstfelter / højre sliders -->
        <div class="grid grid-cols-2 gap-x-6 px-4 pt-2">

            <!-- VENSTRE: tekstfelter -->
            <div class="flex flex-col gap-y-2">
                <div class="flex flex-col">
                    <label class="text-[#f5f5f5] text-xs mb-1">Ølnavn:</label>
                    <input
                        id="oel-navn-input"
                        type="text"
                        placeholder="Cloud Gazing..."
                        class="bg-transparent border border-white/30 text-white text-sm outline-none p-1 w-full rounded"
                    />
                </div>
                <div class="flex flex-col">
                    <label class="text-[#f5f5f5] text-xs mb-1">Beskrivelse:</label>
                    <textarea
                        id="beskrivelse-input"
                        placeholder="Cloud Gazing is a modern West Coast IPA..."
                        rows="3"
                        class="bg-transparent border border-white/30 text-white text-sm outline-none p-1 w-full resize-none rounded"
                    ></textarea>
                </div>

                <div class="flex flex-col">
                    <label class="text-[#f5f5f5] text-xs mb-1">Ølstil:</label>
                    <select
                        id="stil-select"
                        class="bg-[#46484a] border border-white/30 text-white text-sm outline-none p-1 w-full rounded"
                    >
                  
                        <option selected value="#87472d">Ale</option>
                        <option value="#524073" >IPA</option>
                        <option value="#76935e">Lager</option>
                        <option value="#811a2d">Sour</option>
                        <option value="#7dbeb6">Stout</option>
                        <option value="#bea67d">Wheat</option>
                        <option value="#fefdf3">Special</option>
                    </select>
                </div>
            </div>

            <!-- HØJRE: sliders -->
            <div class="flex flex-col">
                <sl-range 
                    id="ctrl-kurver" 
                    label="ABV (%):" 
                    min="0.0" max="16" step="0.1" value="0">
                </sl-range>

                <sl-range 
                    id="ctrl-snit" 
                    label="IBU (bitterhed):" 
                    min="0" max="100" value="0">
                </sl-range>

                <sl-range 
                    id="ctrl-hue" 
                    label="EBC (Farve):" 
                    min="0" max="150" value="0">
                </sl-range>
            </div>

        </div>
    </div>

    <!-- Alt indhold starter under baren -->
    <div class="pt-65"></div>

    <!-- Denne kasse holder både svg og p5sketch oven i hinanden -->
    <div class="relative">

        <!-- LAG 1: p5sketch nederst -->
        <div class="absolute inset-0 z-0">
            <P5Sketch />
        </div>

        <!-- LAG 2: Label SVG (inline, så vi kan opdatere tekst med JS) -->
        <div class="relative z-10 pt-2 w-full" style="aspect-ratio: 2420/1416;">
            <Label />
        </div>
    </div>


        <!-- Gem lable -->
    <div class="w-full flex items-center gap-2 px-4 py-3">
  <span class="text-sm wrap text-black/80">Gem label som:</span>

  <input
    id="export-name"
    type="text"
    value="label-1"
    class="bg-transparent border border-black/30 text-black text-sm outline-none p-2 rounded w-56"
  />
  <button
    id="btn-export-png"
    class="px-3 py-2 rounded bg-black/10 hover:bg-black/20 text-black text-sm"
  >
    Gem PNG
  </button>
</div>
</Layout>

<!-- eksport png -->
<script>
  
    const input = document.getElementById('oel-navn-input') as HTMLInputElement;

input.addEventListener('input', () => {
    const svgTekst = document.getElementById('svg-oel-navn');
    if (svgTekst) {
        svgTekst.querySelector('tspan')!.textContent = input.value || 'Cloud Gazing';

        const maxTegn = 21;
        const baseFontSize = 17;
        const minFontSize = 10;
        const længde = input.value.length;
        const nyStørrelse = længde > maxTegn
            ? Math.max(minFontSize, baseFontSize - (længde - maxTegn) * 0.8)
            : baseFontSize;
        (svgTekst as HTMLElement).style.fontSize = nyStørrelse + 'px';
    }
});

 const beskrivelseInput = document.getElementById('beskrivelse-input') as HTMLTextAreaElement;
beskrivelseInput.addEventListener('input', () => {
    const svgBeskrivelse = document.getElementById('svg-beskrivelse');
    if (!svgBeskrivelse) return;

    const linjer = beskrivelseInput.value
        ? beskrivelseInput.value.match(/.{1,38}/g) || []
        : [
            'Cloud Gazing is a modern West Coast IPA',
            'boasting a blend of hops that express',
            'citrus fruits, evergreen forest, and an',
            'approachable bitterness'
          ];

    svgBeskrivelse.innerHTML = linjer
        .map((linje, i) => `<tspan x="0" dy="${i === 0 ? 0 : 8}">${linje}</tspan>`)
        .join('');

    const maxTegn = 17;
    const baseFontSize = 8;
    const minFontSize = 4;
    const længde = beskrivelseInput.value.length;
    const nyStørrelse = længde > maxTegn
        ? Math.max(minFontSize, baseFontSize - (længde - maxTegn) * 0.03)
        : baseFontSize;
    svgBeskrivelse.setAttribute('font-size', nyStørrelse + 'px');

 
});

    function opdaterStil(stil: string) {
        // Opdater Å-farve direkte i SVG
        // const aaFarve = stilAaFarve[stil] || '#000000';
        const aaFarve = document.getElementById('stil-select')?.value;
        document.getElementById('svg-aa-højre')?.setAttribute('fill', aaFarve);
        document.getElementById('svg-aa-venstre')?.setAttribute('fill', aaFarve);
        document.getElementById('stortåben')?.setAttribute('fill', aaFarve);
    }

    const stilSelect = document.getElementById('stil-select') as HTMLSelectElement;
    stilSelect.addEventListener('change', () => opdaterStil(stilSelect.value));
    
    // Sæt INTET som standard ved load
    opdaterStil('VÆLG');

    // ABV slider opdaterer alkoholprocenten i SVG
    const abvSlider = document.getElementById('ctrl-kurver');
    abvSlider?.addEventListener('sl-input', (e: any) => {
        const val = parseFloat(e.target.value).toFixed(1);
        const alcTspan = document.getElementById('svg-alc-tspan');
        if (alcTspan) {
            alcTspan.textContent = `Alc. ${val}% vol.`;
        }

        
    });

// Skift mellem hvid og sort på infortekst afhængigt af hue sliderens værdi
const hueSlider = document.getElementById('ctrl-hue');
hueSlider?.addEventListener('sl-change', (e: any) => {
    const val = parseFloat(e.target.value);
    const tekstFarve = val > 88 ? '#ffffff' : '#000000';

    // Tekst i disse grupper skal skifte farve
    ['Ingredienser', 'Beskrivelse', 'Holdbarhed'].forEach(id => {
        document.querySelectorAll(`#${id} text`).forEach(el => {
            el.setAttribute('fill', tekstFarve);
        });
    });

    // Det lille ÅBEN-logo (paths + tekst i Producent_logo)
    document.querySelectorAll('#Producent_logo text, #Producent_logo path').forEach(el => {
        el.setAttribute('fill', tekstFarve);

//Få e med
        document.querySelectorAll('#Producent_logo text, #Producent_logo path, #Producent_logo polygon').forEach(el => {
    el.setAttribute('fill', tekstFarve);
});

document.querySelectorAll('#linjer path, #linjer polygon, #linjer rect').forEach(el => {
    el.setAttribute('fill', tekstFarve);
});
    });
});
    

    // PNG eksport
    const btnPng = document.getElementById("btn-export-png");
    const exportName = document.getElementById("export-name") as HTMLInputElement;

    btnPng?.addEventListener("click", () => {
        const s = (window as any).__labelSketch;
        if (!s?.downloadPNG) return console.warn("downloadPNG ikke fundet");
        const filename = (exportName?.value || "label").trim().replace(/[^\w\-]+/g, "_");
        s.downloadPNG(filename);
    });
</script>


<style>
    sl-range {
        padding: 10px 20px;
        border-radius: 8px;
        --sl-color-primary-600: #232323;
        --sl-color-primary-500: #888888;
        --sl-input-label-color: #f5f5f5;
        --sl-input-label-font-size-medium: 14px;   
    }

    sl-color-picker {
        padding: 10px 20px;
    }

    sl-range::part(base) {
        width: 100%;
    }

    
</style>